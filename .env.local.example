# Copy this file to .env.local and add your OpenRouter API key.
# Get a key at https://openrouter.ai/keys

# Server-side key (recommended — never exposed to the browser)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Optional: used for OpenRouter HTTP-Referer header
NEXT_PUBLIC_APP_URL=http://localhost:3000
